---
// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import HeroMicrosoft365 from "@components/Services/Intranets/HeroMicrosoft365.astro";
import LogoCloudMarquee from "@components/LogoCloud/LogoCloudMarquee.astro";
import FeatureCodeToggle from "@components/Feature/FeatureCodeToggle.astro";
import MS365FeatureCardsSmall from "@components/Services/Intranets/MS365FeatureCardsSmall.astro";
import FeatureIntegrations from "@components/Feature/FeatureIntegrations.astro";
import TestimonialsSwiperQuotes from "@components/Testimonials/TestimonialsSwiperQuotes.astro";
import CtaBgImage from "@components/Cta/CtaBgImage.astro";
import FaqAccordions from "@components/Faq/FaqAccordions.astro";
import WebsitePricingTableWithAccordion from "@components/Pricing/Websites/WebsitePricingTableWithAccordion.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
---

<BaseLayout title={siteData.title} description={siteData.description}>
	<HeroMicrosoft365 />
	<!-- <LogoCloudMarquee /> to create new componentwith microsoft 365 product logos-->
	<MS365FeatureCardsSmall />
	<!-- <WebsitePricingTableWithAccordion /> -->
	<!-- <FeatureIntegrations /> -->
	<!-- <TestimonialsSwiperQuotes /> -->
	<!-- <CtaBgImage /> -->
	<!-- <FaqAccordions /> -->
</BaseLayout>
