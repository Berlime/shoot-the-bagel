---
/**
 * * These are alternating side cards with titles, text, and images
 * Recommend using 2 or 3 cards in a row
 */
import { Icon } from "astro-icon/components";

// components
import FeatureCard from "@components/FeatureCard/FeatureCardSideImage.astro";
import Badge from "@components/Badge/Badge.astro";
import Badge2 from "@components/Badge/Badge2.astro";

// images
import image1 from "@images/storm-1.webp";
import image2 from "@images/storm-2.webp";

interface FeatureItem {
	badge2: string; // badge text
	image: ImageMetadata; // an imported image
	title: string;
	description: string;
	href: string; // link to learn more
	buttonText: string; // button text
}

// data
const featureData: FeatureItem[] = [
	{
		badge2: "Functional Design",
		image: image1,
		title: "Outshine with Aesthetics",
		description:
			"Smooth animations that don't distract from the content. Crafted with the best in class design framework. Fits all device screens and accessibility. Instill long lasting first impression.",
		href: "/signup",
		buttonText: "Get Started",
	},
	{
		badge2: "Reduce Daily Tasks",
		image: image2,
		title: "Automate Everything",
		description:
			"Let your website be the ultimate 24/7 salesperson. As your business grows, it will seamlessly expand with you. Freeing you to explore innovative ideas & focus on what you do best. Let your website maximize your reach.",
		href: "/signup",
		buttonText: "Get Started",
	},
	{
		badge2: "Organic Marketing",
		image: image2,
		title: "Bring Your Aftersales to the Next Level",
		description:
			"Enhance customer satisfaction and loyalty with top-tier personalized experience in their purchase. Elevate your brand by making every aftersales interaction a seamless and positive experience.",
		href: "/signup",
		buttonText: "Get Started",
	},
];
---

<section id="feature-side-image" class="my-12 overflow-hidden py-12">
	<div class="site-container">
		<div class="mx-auto mb-16 text-center md:max-w-4xl" data-aos="fade-up">
			<Badge2>🚀 Space is the limit</Badge2>			
      <h2 class="h2 mb-4">Your Vision into Reality</h2>
	  <p
        class="description"
        data-aos="fade-up"
        data-aos-delay=".2"
      >
	  Compelling sleek designs & optimized for performance.<br>
	  Transform your vision into a powerhouse.
	    
      </p>
    </div>
		<div class="flex flex-col gap-16 md:gap-24">
			{
				featureData.map((feature, idx) => (
					<FeatureCard
						badge={feature.badge2}
						title={feature.title}
						description={feature.description}
						image={feature.image}
						imageSide={idx % 2 === 0 ? "right" : "left"}
						href={feature.href}
						buttonText={feature.buttonText}
					/>
				))
			}
		</div>
	</div>
</section>
